# Chat Plugin 配置

# ============================================================
# API 配置 (JSON 列表)
# ============================================================
# 每项字段 (全部必填):
#   name    — API 显示名称，用于 /api <名称> 切换
#   type    — API 协议类型: openai / anthropic (代码自动匹配 endpoint、认证头、请求格式)
#   base    — API 地址 (不含路径，如 https://api.openai.com)
#   key     — API 密钥
#   model   — 默认模型
#
# 协议自动适配 (只需指定 type):
#   type=openai   → chat: /v1/chat/completions,  models: /v1/models,       认证: Bearer
#   type=anthropic → chat: /v1/messages,           models: 不支持,           认证: x-api-key + anthropic-version
#
# 切换 API 时以上所有配置一起生效
#
# 单 API 示例:
# CHAT_APIS=[{"name":"OpenAI","type":"openai","base":"https://api.openai.com","key":"sk-xxx","model":"gpt-4o"}]
#
# 多 API 示例 (OpenAI + Anthropic + DeepSeek):
# CHAT_APIS=[{"name":"OpenAI","type":"openai","base":"https://api.openai.com","key":"sk-xxx","model":"gpt-4o"},{"name":"Claude","type":"anthropic","base":"https://api.anthropic.com","key":"sk-ant-xxx","model":"claude-sonnet-4-6"},{"name":"DeepSeek OpenAI","type":"openai","base":"https://api.deepseek.com","key":"sk-yyy","model":"deepseek-v4-pro"},{"name":"DeepSeek Anthropic","type":"anthropic","base":"https://api.deepseek.com/anthropic","key":"sk-yyy","model":"deepseek-v4-pro"}]
#
# 默认使用的 API (可选，留空=使用第一个)
# CHAT_DEFAULT_API=OpenAI

# ============================================================
# 通用配置
# ============================================================

# 系统提示词文件路径 (完整路径，可选，不设置则不使用提示词)
# 例: CHAT_SYSTEM_PROMPT_FILE=D:\my_prompts\assistant.txt
CHAT_SYSTEM_PROMPT_FILE=

# 白名单 — 允许响应的 QQ 群号 (逗号分隔, 留空=所有群都响应)
CHAT_ALLOW_GROUPS=

# 白名单 — 允许响应的 QQ 号 (逗号分隔, 留空=所有人都响应)
CHAT_ALLOW_USERS=

# 识图功能 (默认启用, 设为 False 关闭)
CHAT_VISION_ENABLED=True

# Temperature 参数 (可选, 0.0~2.0, 留空则使用 API 默认值)
CHAT_TEMPERATURE=
